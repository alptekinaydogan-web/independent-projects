# --- Version control & CI -----------------------------------------------
.git
.gitignore
.github
.gitattributes

# --- Local editor / IDE -------------------------------------------------
.vscode
.idea
*.swp
*.swo
.DS_Store

# --- Environment files (never bake secrets into images) -----------------
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*

# --- Build artefacts ----------------------------------------------------
frontend/node_modules
frontend/build
frontend/coverage
**/node_modules
**/dist
**/coverage
backend/__pycache__
**/__pycache__
**/*.py[cod]
**/*.egg-info
.pytest_cache
.ruff_cache
.mypy_cache

# --- Docker / Compose ---------------------------------------------------
Dockerfile.dev
docker-compose.override.yml

# --- Documentation & tests (kept out of the runtime image) -------------
docs
memory
test_reports
test_result.md
tests
design_guidelines.json
backend/tests
frontend/tests

# --- Emergent workspace metadata (never ship) ---------------------------
.emergent
