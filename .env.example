# ============================================================================
#  Independent Commerce — production environment reference
#
#  Copy this file to `.env` for local Docker Compose runs, or paste the
#  values into the Coolify project's Environment tab for production.
#  Never commit real secrets to git — this file only ships PLACEHOLDERS.
# ============================================================================

# ---- Database (required) ---------------------------------------------------
# Full MongoDB connection URI. In Coolify point this at the linked MongoDB
# service (e.g. mongodb://user:pass@mongo:27017) or a managed provider.
MONGO_URL=mongodb://mongo:27017
DB_NAME=independent_commerce

# ---- Authentication (required) ---------------------------------------------
JWT_SECRET=replace-me-with-a-32-byte-random-string
ADMIN_EMAIL=admin@independentmedia.hub
ADMIN_PASSWORD=replace-me-with-a-strong-password

# ---- Public URL of the deployed app (used in outgoing emails) --------------
FRONTEND_URL=https://commerce.example.com

# ---- CORS ----------------------------------------------------------------
# Comma-separated list of allowed origins. Leave as `*` only for dev/preview.
CORS_ORIGINS=https://commerce.example.com

# ---- Email delivery (Resend) -----------------------------------------------
# When empty, password-reset emails are logged instead of sent.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ---- Optional LLM key (Emergent universal key) -----------------------------
# Only required if features that need an LLM are enabled. Leave blank otherwise.
EMERGENT_LLM_KEY=

# ---- Application metadata --------------------------------------------------
APP_NAME=independent-commerce
